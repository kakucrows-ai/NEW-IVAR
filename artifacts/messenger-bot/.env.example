# ══════════════════════════════════════════════════════
#  ivar Bot — Environment Variables
#  انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────

# Port the dashboard/API listens on (Replit sets this automatically)
PORT=3001

# Dashboard API key — change this before deploying!
DASHBOARD_API_KEY=al-mo9awim

# ── Optional: GitHub AppState Backup ──────────────────

# GitHub Personal Access Token (for auto-backup of appstate.json)
# Scopes needed: repo (read/write contents)
GITHUB_TOKEN=

# ── Optional: CORS ────────────────────────────────────

# Allowed origins for dashboard API (default: all)
CORS_ORIGIN=*

# ══════════════════════════════════════════════════════
# Notes:
#  - appstate.json  : upload via dashboard → 🍪 الجلسة
#  - config.json    : bot name, prefix, admin IDs
#  - Never commit .env or appstate.json to git
# ══════════════════════════════════════════════════════
